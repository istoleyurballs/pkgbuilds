pkgname=system-base
pkgver=2.0.3
pkgrel=1

pkgdesc='System configuration base'
url='https://github.com/istoleyurballs/pkgbuilds'
arch=('any')
license=('GPL-3.0-or-later')

depends=(
  # Needed to boot (except the actual bootloader)
  'base' 'linux' 'linux-firmware' 'btrfs-progs' 'dosfstools'
  'efibootmgr'
  # Maintenance
  'reflector' 'pacman-contrib' 'pacutils' 'smartmontools' 'powertop'
  'archpatch-git'
  # AUR
  'base-devel' 'devtools' 'paru'
  # Dotfiles
  'stow'

  # Drivers
  'intel-ucode' 'intel-media-driver'
  'libva-utils' 'vulkan-tools'

  # Sudo
  'sudo'

  # Shell tools
  'fish' 'nushell' 'starship' 'zellij'
  'bat' 'htop' 'gotop' 'nvtop' 'fastfetch'
  'tree' 'jq' 'jc' 'unzip' 'moreutils' 'tokei'
  'git' 'lazygit'
  'dmidecode' 'systemd-resolvconf' 'wireguard-tools'
  'man-db' 'man-pages'
  'neovim' 'fzf' 'ripgrep'
  'openssh' 'sshfs'
  'imagemagick' 'ffmpeg' 'aria2'
)

source=(
  'vconsole.conf'
  'locale.gen.patch'
  'locale.conf'
  '89-ethernet.network'
  'sudoers.d-allow-sudo-group'
  'makepkg.d-parallel.conf'
  'pacman.conf.patch'
  'reflector.conf.patch'
  'pacreport.conf'
  'archpatch-on-update.hook'
)
install='system-base.install'

package() {
  # Basic stuff
  mkdir -p "$pkgdir"/etc
  ln -sf ../usr/share/zoneinfo/Europe/Paris "$pkgdir"/etc/localtime
  install -Dm0644 vconsole.conf "$pkgdir"/etc/vconsole.conf
  install -Dm0644 locale.conf "$pkgdir"/etc/locale.conf
  
  # Network
  install -Dm0644 89-ethernet.network "$pkgdir"/etc/systemd/network/89-ethernet.network
  # stub resolve.conf is done in the .install

  # Sudo
  install -Dm0700 sudoers.d-allow-sudo-group "$pkgdir"/etc/sudoers.d/allow-sudo-group
  chmod 750 "$pkgdir"/etc/sudoers.d/

  # Archlinux stuff
  install -Dm0644 makepkg.d-parallel.conf "$pkgdir"/etc/makepkg.conf.d/99-parallel.conf
  install -Dm0644 pacreport.conf "$pkgdir"/etc/pacreport.conf

  # Patches setup
  install -Dm0644 locale.gen.patch "$pkgdir"/usr/share/archpatch/patches/etc-locale.gen.patch
  install -Dm0644 pacman.conf.patch "$pkgdir"/usr/share/archpatch/patches/etc-pacman.conf.patch
  install -Dm0644 reflector.conf.patch "$pkgdir"/usr/share/archpatch/patches/etc-xdg-reflector-reflector.conf.patch
  install -Dm0644 archpatch-on-update.hook "$pkgdir"/usr/share/libalpm/hooks/archpatch-on-update.hook
}

