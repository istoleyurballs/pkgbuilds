pkgname=system-ilum
pkgver=2.0.5
pkgrel=1

pkgdesc='System configuration for ilum'
url='https://github.com/istoleyurballs/pkgbuilds'
arch=('any')
license=('GPL-3.0-or-later')

depends=(
  # Needed to boot
  'system-base' 'grub' 'os-prober' 'grub-theme-minegrub-world-selection-git'

  # NVIDIA Drivers
  'nvidia-open' 'nvidia-utils' 'libva-nvidia-driver'
  'nvidia-settings'

  # = Destkop setup
  # Display Manager
  'ly'
  # Session Manager
  'uwsm' 'libnewt'
  # Window Manager & friends
  'hyprland' 'hyprpolkitagent' 'hyprlock' 'hyprpaper' 'hyprsunset'
  # Screenshot
  'hyprshot' 'xdg-desktop-portal-hyprland'
  'hyprpicker' 'qt5-wayland'
  # Status bar
  'waybar'
  # Notification daemon
  'dunst'
  # Base apps
  'rofi-wayland' 'alacritty' 'ranger' 'feh' 'mpv' 'firefox' 'calibre'
  # Sound
  'pipewire' 'wireplumber' 'pipewire-pulse' 'pavucontrol'
  # External apps stuff
  'flatpak' 'docker' 'docker-buildx' 'docker-compose' 'dive' 'k9s' 'kubectl'
  # Steam
  'steam' 'lib32-nvidia-utils' 'lib32-systemd'
  # Fonts
  'ttf-jetbrains-mono-nerd' 'ttf-liberation'
  # Bit random
  'nwg-look' 'papirus-icon-theme' 'brightnessctl' 'wev'
  'vulkan-caps-viewer-wayland'
)

source=(
  'hostname'
  'ilum-grub.nu'
  'ly-config.ini.patch'
  'etc-default-grub.patch'
  'mkinitcpio.conf.patch'
  'hyprland-gaming.desktop'
  'hyprland-gaming-uwsm.desktop'
  'hyprland-tv-hdr.desktop'
  'hyprland-tv-hdr-uwsm.desktop'
  'ilum-flatpak.nu'
)
install='system-ilum.install'

package() {
  # Mountpoints for various things
  # - swapfile
  # - root btrfs subvol
  # - other SSD
  # - homlab sshfs
  # - random stuff that need a mountpoint from time to time
  mkdir -p "$pkgdir"/swap
  mkdir -p "$pkgdir"/mnt/rootfs
  mkdir -p -m 777 "$pkgdir"/mnt/fastass
  mkdir -p -m 777 "$pkgdir"/mnt/lucastrunk
  mkdir -p -m 777 "$pkgdir"/mnt/stuff

  # Basic stuff
  install -Dm0644 hostname "$pkgdir"/etc/hostname

  # Grub
  install -Dm0755 ilum-grub.nu "$pkgdir"/usr/bin/ilum-grub

  # Patches
  install -Dm0644 etc-default-grub.patch "$pkgdir"/usr/share/archpatch/patches/etc-default-grub.patch
  install -Dm0644 mkinitcpio.conf.patch "$pkgdir"/usr/share/archpatch/patches/etc-mkinitcpio.conf.patch
  install -Dm0644 ly-config.ini.patch "$pkgdir"/usr/share/archpatch/patches/etc-ly-config.ini.patch

  # Install custom hyprland sessions
  install -Dm0644 hyprland-gaming.desktop "$pkgdir"/usr/share/wayland-sessions/hyprland-gaming.desktop
  install -Dm0644 hyprland-gaming-uwsm.desktop "$pkgdir"/usr/share/wayland-sessions/hyprland-gaming-uwsm.desktop
  install -Dm0644 hyprland-tv-hdr.desktop "$pkgdir"/usr/share/wayland-sessions/hyprland-tv-hdr.desktop
  install -Dm0644 hyprland-tv-hdr-uwsm.desktop "$pkgdir"/usr/share/wayland-sessions/hyprland-tv-hdr-uwsm.desktop

  # Flatpak
  install -Dm0755 ilum-flatpak.nu "$pkgdir"/usr/bin/ilum-flatpak
}

sha256sums=('5a93eced3b28435ffbd7ac8450c4a3dedcb7d49f793c81a3afe68dc45c49d35a'
