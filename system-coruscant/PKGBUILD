pkgname=system-coruscant
pkgver=1.2.3
pkgrel=1

pkgdesc='System configuration for coruscant'
url='https://github.com/istoleyurballs/pkgbuilds'
arch=('any')
license=('GPL-3.0-or-later')

depends=(
  # Needed to boot (not much)
  'system-base'

  # Intel GPU drivers
  'vulkan-intel' 'intel-media-driver'

  # Container stuff
  'podman' 'podman-compose'
  'k3s-bin' 'kubectl' 'k9s'

  # Media
  'imagemagick' 'ffmpeg' 'aria2'
)

source=(
  'hostname'
  'sudoers.d-allow-passwordless-update-user'
  'coruscant-boot.nu'
  'cmdline.d-coruscant.conf'
  'sshd_config.patch'
  'authorized_keys-root'
  'authorized_keys-lucas'
)
install='system-coruscant.install'

package() {
  # Mountpoints for various things
  # - swapfile
  # - root btrfs subvol
  # - btrfs array
  # - random stuff that need a mountpoint from time to time
  mkdir -p "$pkgdir"/swap
  mkdir -p "$pkgdir"/mnt/rootfs
  mkdir -p -m 777 "$pkgdir"/mnt/lucastrunk
  mkdir -p -m 777 "$pkgdir"/mnt/stuff

  # Basic stuff
  install -Dm0644 hostname "$pkgdir"/etc/hostname

  # Suoders
  install -Dm0700 sudoers.d-allow-passwordless-update-user "$pkgdir"/etc/sudoers.d/allow-passwordless-update-user

  # Boot
  install -Dm0755 coruscant-boot.nu "$pkgdir"/usr/bin/coruscant-boot
  isntall -Dm0644 cmdline.d-coruscant.conf "$pkgdir"/etc/cmdline.d/coruscant.conf

  # Patches
  install -Dm0644 sshd_config.patch "$pkgdir"/usr/share/archpatch/patches/etc-ssh-sshd_config.patch

  # SSH authorized keys keys
  install -Dm0644 authorized_keys-root "$pkgdir"/etc/ssh/authorized_keys.d/root
  install -Dm0644 authorized_keys-lucas "$pkgdir"/etc/ssh/authorized_keys.d/lucas
}

sha256sums=('69c16e06ed9bd5dc608d50c03fc4911c57e0d997f19cb758fce7f3095dd21edf'
