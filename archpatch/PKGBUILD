_pkgname=archpatch
pkgname=$_pkgname
pkgver=0.1.3
pkgrel=1
pkgdesc='Utility to apply patch on top of pacman owned configuration files'
arch=('i686' 'x86_64' 'arm' 'armv7h' 'aarch64')
url=https://github.com/istoleyurballs/archpatch
license=('GPL-3.0-or-later')

provides=('archpatch')
conflicts=('archpatch')
depends=('pacman' 'pacutils' 'libalpm.so')
makedepens=('cargo')

source=("https://github.com/istoleyurballs/archpatch/archive/refs/tags/v$pkgver.tar.gz")

build() {
  cd "$srcdir/$_pkgname-$pkgver"
  cargo build --release
}

package() {
  cd "$srcdir/$_pkgname-$pkgver"
  install -Dm0755 target/release/archpatch "$pkgdir"/usr/bin/archpatch
}

sha256sums=('b7b343fd857705c9c8e1ba1d50b0f65f8794af8ab957273cd005a2c57eeaa710')
